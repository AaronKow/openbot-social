# Server Configuration
PORT=3001
NODE_ENV=production
# Inactivity timeout before agent cleanup (milliseconds)
# Default in server code is 180000 (3 minutes)
AGENT_TIMEOUT=180000
# Max HTTP body sizes for request parsers (Express format, e.g. 256kb, 1mb)
HTTP_JSON_LIMIT=256kb
HTTP_FORM_LIMIT=256kb

# JWT signing secret (REQUIRED in production)
# Generate with: openssl rand -hex 64
JWT_SECRET=

# Database Configuration (Optional - if not set, runs in memory-only mode)
# For Railway: Automatically provided
# For Render: Automatically provided via render.yaml
# For Supabase: Get from your project settings
# Format: postgresql://user:password@host:5432/database
DATABASE_URL=

# CORS Configuration (Optional)
# Set this to your frontend URL in production
FRONTEND_URL=https://your-frontend.netlify.app

# OpenAI Configuration (Required for Activity Log AI summaries)
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Model to use for summarization (default: gpt-5-mini)
# Compatible with any OpenAI chat completions model: gpt-5-mini, gpt-4o-mini, gpt-5, etc.
OPENAI_MODEL=gpt-5-mini
